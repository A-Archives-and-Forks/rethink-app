<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_vpn_header_gradient"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:contentScrim="@drawable/bg_vpn_header_gradient"
            app:expandedTitleTextAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            app:collapsedTitleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:expandedTitleMarginStart="24dp"
            app:expandedTitleMarginBottom="40dp"
            app:titleEnabled="true">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_world_map"
                android:scaleType="centerCrop"
                android:alpha="0.08"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_hero_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="20dp"
                android:textSize="13sp"
                android:textColor="?attr/primaryTextColor"
                android:alpha="0.7"
                android:ellipsize="end"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.8" />

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:title="" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="80dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/no_subscription_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/divider"
                app:cardBackgroundColor="?attr/background"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center_horizontal"
                        android:src="@drawable/ic_rethink_plus"
                        android:tint="?attr/accentGood"
                        android:scaleType="centerInside" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_no_sub_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="@string/manage_sub_no_sub_title"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_no_sub_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/manage_sub_no_sub_desc"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="4dp"
                        android:background="?attr/divider" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/manage_sub_no_sub_feature_1"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/manage_sub_no_sub_feature_2"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/manage_sub_no_sub_feature_3"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/manage_sub_no_sub_feature_4"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_explore_plans"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="@string/manage_sub_no_sub_cta"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:backgroundTint="?attr/accentGood" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:text="@string/manage_sub_no_sub_restore_hint"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_restore_purchase"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/manage_sub_no_sub_restore_btn"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        app:cornerRadius="12dp"
                        app:strokeColor="?attr/accentGood"
                        android:textColor="?attr/accentGood" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/subscription_details_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="?attr/divider"
                app:cardBackgroundColor="?attr/background"
                app:layout_constraintTop_toBottomOf="@id/no_subscription_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/accentGood"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="16dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="6dp"
                            android:text="@string/lbl_active"
                            android:textColor="?attr/homeScreenHeaderTextColor"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </com.google.android.material.card.MaterialCardView>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_status_description"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/status_active_description"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/status_badge"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:visibility="visible" />

                    <View
                        android:id="@+id/divider_1"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/divider"
                        app:layout_constraintTop_toBottomOf="@id/tv_status_description"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/label_current_plan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/current_plan"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/divider_1"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_plan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/plan_name_placeholder"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/primaryTextColor"
                        app:layout_constraintTop_toBottomOf="@id/label_current_plan"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/divider_2"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/divider"
                        app:layout_constraintTop_toBottomOf="@id/tv_plan"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/label_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/subscription_price"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/divider_2"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/price_placeholder"
                        android:textSize="15sp"
                        android:textColor="?attr/primaryTextColor"
                        app:layout_constraintTop_toBottomOf="@id/label_price"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/divider_3"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/divider"
                        app:layout_constraintTop_toBottomOf="@id/tv_price"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/label_billing_cycle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/billing_cycle"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/divider_3"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_billing_cycle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/monthly_plan"
                        android:textSize="15sp"
                        android:textColor="?attr/primaryTextColor"
                        app:layout_constraintTop_toBottomOf="@id/label_billing_cycle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/divider_activation"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/divider"
                        app:layout_constraintTop_toBottomOf="@id/tv_billing_cycle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/label_activation_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/dashboard_activated_label"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/divider_activation"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_activation_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="15sp"
                        android:textColor="?attr/primaryTextColor"
                        app:layout_constraintTop_toBottomOf="@id/label_activation_date"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/divider_expiry"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:visibility="gone"
                        android:background="?attr/divider"
                        app:layout_constraintTop_toBottomOf="@id/tv_activation_date"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/label_expiry_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/dashboard_expiry_label"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/divider_expiry"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_expiry_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="15sp"
                        android:textColor="?attr/primaryTextColor"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/label_expiry_date"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/divider_token"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/divider"
                        app:layout_constraintTop_toBottomOf="@id/tv_expiry_date"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/label_token"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/support_sub_token_label"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/divider_token"
                        app:layout_constraintStart_toStartOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_purchase_token"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="13sp"
                        android:textColor="?attr/primaryLightColorText"
                        android:fontFamily="monospace"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:layout_constraintTop_toBottomOf="@id/label_token"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/features_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="?attr/divider"
                app:cardBackgroundColor="?attr/background"
                app:layout_constraintTop_toBottomOf="@id/subscription_details_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_features_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/plan_includes"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/primaryTextColor" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_features"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingMultiplier="1.4"
                        android:textSize="14sp"
                        android:textColor="?attr/secondaryTextColor"
                        tools:text="• Unlimited bandwidth\n• Ad-free experience\n• Priority support" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/expiring_banner_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/accentWarning"
                app:layout_constraintTop_toBottomOf="@id/features_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_expiring_banner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="?attr/primaryTextColor"
                    tools:text="⚠ Your access expires in 14 days. Tap to renew." />

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/action_buttons_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/expiring_banner_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/cancel_subscription"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="?attr/accentBad"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="?attr/accentBad"
                    app:icon="@drawable/ic_cross"
                    app:iconTint="?attr/accentBad"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_revoke"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/revoke_subscription"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    app:strokeWidth="1.5dp"
                    android:textColor="?attr/accentBad"
                    app:strokeColor="?attr/accentBad"
                    app:icon="@drawable/ic_info_white"
                    app:iconTint="?attr/accentBad"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_renew"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/renew_subscription"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    android:textColor="?attr/secondaryTextColor"
                    app:strokeColor="?attr/accentGood"
                    app:icon="@drawable/ic_refresh"
                    app:iconTint="?attr/accentGood"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    tools:visibility="visible" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cancel_note_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    tools:visibility="visible">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_cancel_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="@string/cancel_subscription_note"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </com.google.android.material.card.MaterialCardView>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_manage_subscription_on_google_play"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:visibility="gone"
                    android:text="@string/manage_on_google_play"
                    android:textColor="?attr/accentGood"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="?attr/background"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="28dp"
                android:paddingEnd="28dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/progress_spinner"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:indeterminateTint="?attr/accentGood" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_loading_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/primaryTextColor"
                        tools:text="Cancelling subscription" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_loading_sub_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="13sp"
                    android:textColor="?attr/primaryLightColorText"
                    android:lineSpacingMultiplier="1.3"
                    tools:text="Please do not close the app" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    android:background="?attr/divider" />

                <LinearLayout
                    android:id="@+id/step_row_validating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_validating"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_validating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_validating"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step_row_server"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_server"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_server"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_contacting_server"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step_row_local"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_local"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_local"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_updating"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step_row_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_refresh"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_refresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_refreshing"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
